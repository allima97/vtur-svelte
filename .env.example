# Supabase
PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Dexie Cloud (opcional)
# VITE_DEXIE_CLOUD_URL=https://seu-projeto.dexie.cloud

# Cloudflare Turnstile (opcional — protege formulários de auth contra bots)
# Obtenha em: https://dash.cloudflare.com/?to=/:account/turnstile
PUBLIC_TURNSTILE_SITE_KEY=0x00000000000000000000FF
TURNSTILE_SECRET_KEY=0x0000000000000000000000000000000000000000

# Ambiente
PUBLIC_ENVIRONMENT=development
