    "dexie-cloud-addon": "^4.3.9",
    "flowbite-svelte": "^0.48.0",
    "flowbite-svelte-icons": "^2.0.0",
    "hono": "^4.11.9",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-svelte": "^1.0.1",
    "pdfjs-dist": "^5.6.205",
    "xlsx": "^0.18.5"
